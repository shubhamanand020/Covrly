# ---- Core ----
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/?retryWrites=true&w=majority
PORT=8000
COVRLY_DB_NAME=covrly
COVRLY_JWT_SECRET=your_jwt_secret_here
COVRLY_CORS_ORIGINS=https://your-vercel-frontend.vercel.app

# ---- External API Keys ----
OPENWEATHER_API_KEY=your_openweather_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ---- Background Monitor ----
COVRLY_ENABLE_BACKGROUND_TRIGGER_MONITOR=true
COVRLY_BACKGROUND_LOCATION_MAX_AGE_SECONDS=900
COVRLY_TRAFFIC_MIN_DURATION_SECONDS=300
COVRLY_TRAFFIC_RATIO_THRESHOLD=1.5
COVRLY_TRAFFIC_DESTINATION_OFFSET=0.01
COVRLY_TRIGGER_DUPLICATE_RADIUS_METERS=100
COVRLY_TRIGGER_DUPLICATE_WINDOW_SECONDS=300

# ---- Registration OTP ----
COVRLY_OTP_EXPIRY_MINUTES=10
COVRLY_OTP_MAX_ATTEMPTS=5
COVRLY_OTP_SECRET=

# ---- SMTP (OTP Emails) ----
COVRLY_SMTP_HOST=smtp.gmail.com
COVRLY_SMTP_PORT=587
COVRLY_SMTP_USERNAME=your_email@gmail.com
COVRLY_SMTP_PASSWORD=your_app_password
COVRLY_SMTP_FROM_EMAIL=your_email@gmail.com
COVRLY_SMTP_USE_TLS=true
COVRLY_SMTP_USE_SSL=false
